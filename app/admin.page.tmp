'use client'
import { useState, useEffect, useCallback } from 'react'
import AuthGuard from '@/components/AuthGuard'
import HomeButton from '@/components/HomeButton'
import GameMap from '@/components/GameMap'
import Scoreboard from '@/components/Scoreboard'
import Timer from '@/components/Timer'
import clsx from 'clsx'
import {
  RefreshCw, ChevronLeft, ChevronRight, Play, Square,
  Plus, Zap, RotateCcw, Map, History, Trophy,
  LayoutDashboard, Crown, Users, CheckCircle2, Clock,
} from 'lucide-react'
import { HOUSE_COLORS, HOUSE_NAMES, SHEET_ID, TOTAL_WAVES, DISASTER_AREAS } from '@/lib/constants'
import {
  getGameState, setGameState, getMapOwnership, setMapOwnership,
  getSubmissionsForWave, getSubmissions, setActiveDisaster,
  getActiveDisasterForWave, subscribeStore,
} from '@/lib/store'

const D_EMOJI   = ['🌊','🌋','🔥','🌪️','☀️','💥','🌧️','❄️','⚡']
const D_NAMES   = ['น้ำท่วม','แผ่นดินไหว','ไฟป่า','พายุ','แล้ง','ภัย 6','ภัย 7','ภัย 8','ภัย 9']

function AdminContent() {
  const [gs,          setGS]          = useState(getGameState)
  const [ownership,   setOwnership]   = useState(getMapOwnership)
  const [tab,         setTab]         = useState<'dashboard'|'map'|'history'|'leaderboard'>('dashboard')
  const [selBaan,     setSelBaan]     = useState<number|null>(null)
  const [selWave,     setSelWave]     = useState(1)
  const [totalScores, setTotalScores] = useState<{baan:number;score:number}[]>([])
  const [waveScores,  setWaveScores]  = useState<Record<number,{baan:number;score:number}[]>>({})
  const [filterDis,   setFilterDis]   = useState<number|null>(null)
  const [kingDis,     setKingDis]     = useState<number|null>(null)
  const [toast,       setToast]       = useState<{msg:string;type:'ok'|'warn'|'err'}>()
  const [duration,    setDuration]    = useState('10')
  const [processing,  setProcessing]  = useState(false)

  const notify = (msg:string, type:'ok'|'warn'|'err'='ok') => {
    setToast({msg,type}); setTimeout(()=>setToast(undefined), 3500)
  }

  const applyGS = (patch: Parameters<typeof setGameState>[0]) => {
    setGameState(patch); setGS(getGameState())
  }

  // ── Fetch all sheet scores ──────────────────────────────
  const fetchAll = useCallback(async () => {
    try {
      const fetchSheet = async (sheet: string) => {
        const url  = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:json&sheet=${encodeURIComponent(sheet)}`
        const text = await (await fetch(url,{cache:'no-store'})).text()
        const js   = text.match(/google\.visualization\.Query\.setResponse\(([\s\S]*)\)/)?.[1]
        return js ? (JSON.parse(js)?.table?.rows ?? []) : []
      }

      // Total
      const totalRows: any[] = await fetchSheet('TOTALSCORE')
      setTotalScores(totalRows
        .filter((r:any)=>!isNaN(parseInt(String(r?.c?.[0]?.v??''))))
        .map((r:any)=>({ baan:parseInt(String(r.c[0].v)), score:parseFloat(String(r.c[1]?.v??0))||0 })))

      // Per-wave
      const wv: Record<number,{baan:number;score:number}[]> = {}
      for (let w=1; w<=TOTAL_WAVES; w++) {
        try {
          const rows: any[] = await fetchSheet(`Wave ${w}`)
          wv[w] = rows
            .filter((r:any)=>!isNaN(parseInt(String(r?.c?.[0]?.v??''))))
            .map((r:any)=>({ baan:parseInt(String(r.c[0].v)), score:parseFloat(String(r.c[20]?.v??r.c[1]?.v??0))||0 }))
        } catch {}
      }
      setWaveScores(wv)
    } catch(e){ console.error(e) }
  }, [])

  useEffect(()=>{ fetchAll(); const t=setInterval(fetchAll,15000); return()=>clearInterval(t) },[fetchAll])

  useEffect(()=>{
    const u=subscribeStore(()=>{ setGS(getGameState()); setOwnership(getMapOwnership()) })
    return u
  },[])

  useEffect(()=>{ setKingDis(getActiveDisasterForWave(gs.currentWave)) },[gs.currentWave])

  // ── Controls ────────────────────────────────────────────
  const gotoWave = (w:number) => {
    applyGS({currentWave:w, isOpen:false, timerEnd:null})
    notify(`➡ เข้าสู่ Wave ${w}`)
  }
  const startTimer = () => {
    const mins = parseFloat(duration)||10
    applyGS({isOpen:true, timerEnd:new Date(Date.now()+mins*60000).toISOString(), duration:mins})
    notify(`▶ เปิดรับข้อมูล ${mins} นาที`)
  }
  const stopTimer = () => { applyGS({isOpen:false}); notify('⏹ ปิดรับข้อมูลแล้ว') }
  const addTime = (m:number) => {
    const cur = gs.timerEnd ? new Date(gs.timerEnd).getTime() : Date.now()
    applyGS({timerEnd:new Date(Math.max(Date.now(),cur)+m*60000).toISOString(), isOpen:true})
    notify(`+${m} นาที`)
  }
  const processWave = () => {
    setProcessing(true)
    const subs = getSubmissionsForWave(gs.currentWave)
    if (!subs.length) { notify('ยังไม่มีการส่งข้อมูล','warn'); setProcessing(false); return }
    const areaMap: Record<string,{baan:number;amount:number}[]> = {}
    for (const s of subs)
      for (const b of s.bets) {
        if (!areaMap[b.area]) areaMap[b.area]=[]
        areaMap[b.area].push({baan:s.baan,amount:b.amount})
      }
    const newOwn = {...ownership}
    const results: string[] = []
    for (const [area,bids] of Object.entries(areaMap)) {
      bids.sort((a,b)=>b.amount-a.amount)
      newOwn[area]=bids[0].baan
      results.push(`${area}→${bids[0].baan}`)
    }
    setMapOwnership(newOwn); setOwnership(newOwn)
    notify(`✓ Wave ${gs.currentWave}: ${results.slice(0,4).join(', ')}${results.length>4?'…':''}`)
    setProcessing(false)
  }
  const resetMap = () => {
    if (!confirm('รีเซ็ต Map ทั้งหมด?')) return
    setMapOwnership({}); setOwnership({}); notify('🗺 Reset Map แล้ว')
  }

  const submittedBaans = getSubmissionsForWave(gs.currentWave).map(s=>s.baan)
  const waveSubmissions = getSubmissionsForWave(selWave).filter(s=>!selBaan||s.baan===selBaan)

  // ── Toast color ─────────────────────────────────────────
  const toastStyle = toast?.type==='err'
    ? 'border-red-500/30 bg-red-950/60'
    : toast?.type==='warn'
    ? 'border-yellow-500/30 bg-yellow-950/60'
    : 'border-emerald-500/30 bg-emerald-950/60'

  return (
    <div className="site-shell h-screen flex flex-col overflow-hidden">

      {/* Ambient */}
      {/* Toast */}
      {toast && (
        <div className={clsx(
          'fixed top-5 right-5 z-50 glass rounded-xl px-4 py-3 text-sm text-white border',
          'max-w-xs shadow-2xl animate-[fadeUp_0.3s_ease-out] pointer-events-none',
          toastStyle
        )}>
          {toast.msg}
        </div>
      )}

      {/* ── Header ─────────────────────────────────────── */}
      <header className="site-topbar flex-shrink-0">
        <div className="site-container site-nav">
        <HomeButton />
        <div className="divider-v h-5" />
        <div>
          <h1 className="font-display font-bold text-base md:text-lg text-white leading-none">
            ⚙️ Admin Panel
          </h1>
          <p className="text-2xs text-slate-600 mt-0.5">ควบคุมเกม · จัดการรอบ · ข้อมูลหลังบ้าน</p>
        </div>

        <div className="flex-1" />

        <Timer endTime={gs.timerEnd} isOpen={gs.isOpen} compact />

        <div className={clsx('badge', gs.isOpen?'badge-green':'badge-red')}>
          <span className={clsx('status-dot', gs.isOpen?'online':'offline')} />
          <span className="hidden sm:block">{gs.isOpen?'OPEN':'CLOSED'}</span>
        </div>

        <div className="badge badge-blue">
          <span className="font-mono">W{gs.currentWave}/{TOTAL_WAVES}</span>
        </div>

        <button onClick={fetchAll} className="btn btn-ghost py-2 px-2.5">
          <RefreshCw size={13} />
        </button>
        </div>
      </header>

      {/* ── Two-column layout ──────────────────────────── */}
      <div className="site-container py-6 flex-1 flex overflow-hidden relative z-10 gap-5">

        {/* ── Left: Data viewer ──────────────────────── */}
        <div className="site-card flex-1 flex flex-col overflow-hidden min-w-0">

          {/* Sub-tabs */}
          <div className="flex items-center gap-2 px-4 pt-3 pb-2.5 flex-shrink-0 flex-wrap
            border-b border-white/5">
            {([
              ['dashboard','dashboard','Dashboard',<LayoutDashboard size={12}/>],
              ['map','map','MAP',<Map size={12}/>],
              ['history','history','History',<History size={12}/>],
              ['leaderboard','leaderboard','Leaderboard',<Trophy size={12}/>],
            ] as const).map(([value,,label,icon])=>(
              <button key={value} onClick={()=>setTab(value as any)}
                className={clsx('btn py-1.5 px-3.5 text-xs gap-2',
                  tab===value
                    ?'bg-blue-500/15 text-blue-400 border border-blue-500/25'
                    :'btn-ghost')}>
                {icon} {label}
              </button>
            ))}

            {/* Selectors for history/leaderboard */}
            {(tab==='history'||tab==='leaderboard') && (
              <div className="flex items-center gap-2 ml-auto flex-wrap">
                <div className="flex gap-1">
                  {Array.from({length:TOTAL_WAVES},(_,i)=>i+1).map(w=>(
                    <button key={w} onClick={()=>setSelWave(w)}
                      className={clsx('w-7 h-7 rounded-lg font-display text-xs font-bold transition-all',
                        selWave===w?'bg-blue-500/20 text-blue-400 border border-blue-500/35':'btn-ghost text-slate-500')}>
                      {w}
                    </button>
                  ))}
                </div>
                <select value={selBaan||''} onChange={e=>setSelBaan(e.target.value?parseInt(e.target.value):null)}
                  className="input-base py-1.5 text-xs w-auto px-3">
                  <option value="">ทุกบ้าน</option>
                  {Array.from({length:12},(_,i)=>i+1).map(b=>(
                    <option key={b} value={b}>{HOUSE_NAMES[b]}</option>
                  ))}
                </select>
              </div>
            )}

            {/* Disaster filter for map */}
            {tab==='map' && (
              <div className="flex items-center gap-1.5 ml-auto flex-wrap">
                {D_NAMES.slice(0,5).map((n,i)=>(
                  <button key={i+1} onClick={()=>setFilterDis(filterDis===i+1?null:i+1)}
                    className={clsx('btn py-1.5 px-2.5 text-xs',
                      filterDis===i+1?'bg-red-500/15 text-red-400 border border-red-500/25':'btn-ghost')}>
                    {D_EMOJI[i]}<span className="hidden lg:block ml-1">{n}</span>
                  </button>
                ))}
              </div>
            )}
          </div>

          {/* Tab content */}
          <div className="flex-1 overflow-y-auto p-4 md:p-5 space-y-5">

            {/* ── DASHBOARD ── */}
            {tab==='dashboard' && (
              <>
                {/* Submission status grid */}
                <div className="site-card-soft p-5">
                  <div className="flex items-center justify-between mb-4">
                    <p className="text-label">Wave {gs.currentWave} · Submissions</p>
                    <div className="flex items-center gap-3">
                      <span className="badge badge-green">{submittedBaans.length}/12 ส่งแล้ว</span>
                      {12-submittedBaans.length>0 && (
                        <span className="badge badge-red">{12-submittedBaans.length} รอ</span>
                      )}
                    </div>
                  </div>
                  <div className="grid grid-cols-4 sm:grid-cols-6 md:grid-cols-4 lg:grid-cols-6 gap-2">
                    {Array.from({length:12},(_,i)=>i+1).map(b=>{
                      const done = submittedBaans.includes(b)
                      const sub  = getSubmissionsForWave(gs.currentWave).find(s=>s.baan===b)
                      return (
                        <div key={b}
                          className={clsx(
                            'rounded-xl p-2.5 text-center border transition-all cursor-default',
                            done
                              ? 'bg-green-500/8 border-green-500/25'
                              : 'bg-slate-900/50 border-white/5'
                          )}
                          title={done && sub ? sub.bets.map(x=>`${x.area}:${x.amount}`).join(', ') : 'ยังไม่ส่ง'}>
                          <div className="font-display font-bold text-xs leading-none"
                            style={{color:HOUSE_COLORS[b]}}>
                            {b}
                          </div>
                          <div className={clsx('text-lg mt-1',done?'text-green-400':'text-slate-800')}>
                            {done ? <CheckCircle2 size={16} className="mx-auto" /> : <Clock size={16} className="mx-auto opacity-30"/>}
                          </div>
                          {done && sub?.isKing && (
                            <Crown size={10} className="text-yellow-400 mx-auto mt-0.5" />
                          )}
                        </div>
                      )
                    })}
                  </div>
                </div>

                {/* Ownership summary */}
                <div className="site-card-soft p-5">
                  <p className="text-label mb-4">Map Ownership</p>
                  <div className="space-y-1.5">
                    {Array.from({length:12},(_,i)=>i+1).map(b=>{
                      const areas = Object.entries(ownership).filter(([,v])=>v===b).map(([k])=>k)
                      return (
                        <div key={b} className="flex items-center gap-3 site-card-soft px-3 py-2">
                          <div className="w-2 h-2 rounded-full flex-shrink-0"
                            style={{background:HOUSE_COLORS[b]}} />
                          <span className="font-display font-semibold text-xs w-20 flex-shrink-0"
                            style={{color:HOUSE_COLORS[b]}}>
                            {HOUSE_NAMES[b]}
                          </span>
                          <div className="flex-1 flex flex-wrap gap-1">
                            {areas.map(a=>(
                              <span key={a} className="font-mono text-2xs px-1.5 py-0.5 rounded-md bg-white/5 text-slate-400">{a}</span>
                            ))}
                            {areas.length===0&&<span className="text-2xs text-slate-700">—</span>}
                          </div>
                          <span className="font-mono text-xs text-slate-500 flex-shrink-0">{areas.length}</span>
                        </div>
                      )
                    })}
                  </div>
                </div>

                {/* All-wave overview table */}
                <div className="site-card-soft p-5">
                  <p className="text-label mb-4">All Waves Overview</p>
                  <div className="overflow-x-auto">
                    <table className="w-full text-xs">
                      <thead>
                        <tr className="border-b border-white/5">
                          <th className="text-left text-label pb-3 pr-4">บ้าน</th>
                          {Array.from({length:TOTAL_WAVES},(_,i)=>i+1).map(w=>(
                            <th key={w} className={clsx('text-label pb-3 px-3 text-center',
                              w===gs.currentWave?'text-blue-400':'')}>
                              W{w}
                            </th>
                          ))}
                        </tr>
                      </thead>
                      <tbody>
                        {Array.from({length:12},(_,i)=>i+1).map(b=>(
                          <tr key={b} className="border-b border-white/5 hover:bg-white/2 transition-colors">
                            <td className="py-2.5 pr-4">
                              <div className="flex items-center gap-2">
                                <div className="w-2 h-2 rounded-full" style={{background:HOUSE_COLORS[b]}} />
                                <span style={{color:HOUSE_COLORS[b]}}
                                  className="font-display font-semibold text-xs">
                                  {HOUSE_NAMES[b]}
                                </span>
                              </div>
                            </td>
                            {Array.from({length:TOTAL_WAVES},(_,i)=>i+1).map(w=>{
                              const sub = getSubmissions().find(s=>s.baan===b&&s.wave===w)
                              return (
                                <td key={w} className="py-2.5 px-3 text-center">
                                  {sub
                                    ? <span title={sub.bets.map(x=>`${x.area}:${x.amount}`).join(', ')}>
                                        <CheckCircle2 size={13} className="text-green-400 mx-auto" />
                                      </span>
                                    : <span className="text-slate-800">–</span>}
                                </td>
                              )
                            })}
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                </div>
              </>
            )}

            {/* ── MAP ── */}
            {tab==='map' && (
              <div className="site-card-soft p-5 md:p-6">
                <GameMap ownership={ownership} filterDisaster={filterDis}
                  kingDisaster={getActiveDisasterForWave(gs.currentWave)} readOnly />
              </div>
            )}

            {/* ── HISTORY ── */}
            {tab==='history' && (
              <div className="site-card-soft p-5">
                <p className="text-label mb-4">
                  Wave {selWave} · {selBaan?HOUSE_NAMES[selBaan]:'ทุกบ้าน'}
                </p>
                {waveSubmissions.length===0 ? (
                  <div className="flex flex-col items-center py-16 text-slate-700">
                    <div className="text-3xl mb-3 opacity-40">📭</div>
                    <div className="text-sm">ยังไม่มีข้อมูล Wave {selWave}</div>
                  </div>
                ) : (
                  <div className="space-y-3">
                    {waveSubmissions.map(sub=>(
                      <div key={`${sub.baan}-${sub.wave}`} className="site-card-soft p-4">
                        <div className="flex items-center gap-2.5 mb-3">
                          <div className="w-2.5 h-2.5 rounded-full flex-shrink-0"
                            style={{background:HOUSE_COLORS[sub.baan],
                              boxShadow:`0 0 6px ${HOUSE_COLORS[sub.baan]}80`}} />
                          <span className="font-display font-bold text-sm"
                            style={{color:HOUSE_COLORS[sub.baan]}}>
                            {HOUSE_NAMES[sub.baan]}
                          </span>
                          {sub.isKing&&<span className="badge badge-gold gap-1"><Crown size={9}/>KING</span>}
                          {sub.kingDisaster&&(
                            <span className="badge badge-red">⚠ #{sub.kingDisaster} {D_EMOJI[(sub.kingDisaster-1)%9]}</span>
                          )}
                          <span className="ml-auto font-mono text-2xs text-slate-700">{sub.timestamp}</span>
                        </div>
                        <div className="flex flex-wrap gap-2 mb-2.5">
                          {sub.bets.map(bet=>(
                            <div key={bet.area} className="site-card-soft px-3 py-1.5 flex items-center gap-2">
                              <span className="font-display font-bold text-xs text-slate-300">{bet.area}</span>
                              <span className="font-mono text-xs text-orange-400">{bet.amount.toLocaleString()}</span>
                            </div>
                          ))}
                          {sub.bets.length===0&&<span className="text-2xs text-slate-600">ไม่มีการลงทุน</span>}
                        </div>
                        {sub.bets.length>0&&(
                          <div className="pt-2.5 border-t border-white/5 flex justify-between">
                            <span className="text-2xs text-slate-600">รวม</span>
                            <span className="font-mono text-xs text-orange-400">
                              {sub.bets.reduce((s,b)=>s+b.amount,0).toLocaleString()}
                            </span>
                          </div>
                        )}
                      </div>
                    ))}
                  </div>
                )}
              </div>
            )}

            {/* ── LEADERBOARD ── */}
            {tab==='leaderboard' && (
              <div className="space-y-4">
                <div className="site-card-soft p-5">
                  <p className="text-label mb-4">Total Score (รวมทุก Wave)</p>
                  <Scoreboard entries={totalScores} showRewards compact />
                </div>
                <div className="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
                  {Array.from({length:TOTAL_WAVES},(_,i)=>i+1).map(w=>(
                    <div key={w} className="site-card-soft p-4">
                      <div className="flex items-center justify-between mb-3">
                        <p className="text-label">Wave {w}</p>
                        {w===gs.currentWave&&<span className="badge badge-blue">Current</span>}
                      </div>
                      {waveScores[w]?.length
                        ? <Scoreboard entries={waveScores[w]} compact />
                        : <div className="text-center py-8 text-slate-700 text-xs">ยังไม่มีข้อมูล</div>}
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>

        {/* ── Right: Control panel ────────────────────── */}
        <div className="w-72 xl:w-80 flex-shrink-0 flex flex-col overflow-y-auto p-4 gap-4 hidden md:flex">

          {/* Wave control */}
          <div className="site-card-soft p-5">
            <p className="text-label mb-4">Wave Control</p>
            <div className="flex items-center justify-between mb-4">
              <button onClick={()=>gs.currentWave>1&&gotoWave(gs.currentWave-1)}
                disabled={gs.currentWave<=1}
                className="btn btn-ghost p-2.5 disabled:opacity-20">
                <ChevronLeft size={18} />
              </button>
              <div className="text-center">
                <div className="font-display font-black text-6xl text-blue-400 leading-none"
                  style={{textShadow:'0 0 24px rgba(59,130,246,0.7)'}}>
                  {gs.currentWave}
                </div>
                <div className="text-label mt-2">/ {TOTAL_WAVES} WAVES</div>
              </div>
              <button onClick={()=>gs.currentWave<TOTAL_WAVES&&gotoWave(gs.currentWave+1)}
                disabled={gs.currentWave>=TOTAL_WAVES}
                className="btn btn-ghost p-2.5 disabled:opacity-20">
                <ChevronRight size={18} />
              </button>
            </div>
            {/* Progress dots */}
            <div className="flex gap-2">
              {Array.from({length:TOTAL_WAVES},(_,i)=>i+1).map(w=>(
                <button key={w} onClick={()=>gotoWave(w)} className="flex-1">
                  <div className={clsx(
                    'h-1.5 rounded-full transition-all duration-300',
                    w<gs.currentWave  ? 'bg-blue-600'
                    : w===gs.currentWave ? 'bg-blue-400'
                    : 'bg-slate-800'
                  )} />
                </button>
              ))}
            </div>
          </div>

          {/* Timer */}
          <div className="site-card-soft p-5">
            <p className="text-label mb-4">Timer Control</p>
            <div className="flex items-center gap-2 mb-3">
              <input type="number" min={1} max={120} value={duration}
                onChange={e=>setDuration(e.target.value)}
                className="input-base text-center font-mono text-lg py-2.5 flex-1" />
              <span className="text-sm text-slate-500 flex-shrink-0 font-display">นาที</span>
            </div>
            <div className="grid grid-cols-2 gap-2 mb-3">
              <button onClick={startTimer} className="btn btn-success gap-2 py-3 text-sm">
                <Play size={14} fill="currentColor" /> เปิด
              </button>
              <button onClick={stopTimer} className="btn btn-danger gap-2 py-3 text-sm">
                <Square size={14} fill="currentColor" /> ปิด
              </button>
            </div>
            <div className="flex gap-2">
              {[1,2,5,10].map(m=>(
                <button key={m} onClick={()=>addTime(m)} disabled={!gs.isOpen}
                  className="flex-1 btn btn-ghost py-2 text-xs disabled:opacity-25 gap-1">
                  <Plus size={10}/>{m}m
                </button>
              ))}
            </div>
          </div>

          {/* King Disaster */}
          <div className="site-card-soft p-5">
            <div className="flex items-center gap-2 mb-4">
              <Crown size={14} className="text-yellow-400" />
              <p className="text-label">King's Disaster · W{gs.currentWave}</p>
            </div>
            <div className="grid grid-cols-3 gap-1.5 mb-2">
              {D_NAMES.map((name,i)=>{
                const n=i+1; const active=kingDis===n
                return (
                  <button key={n}
                    onClick={()=>{
                      const next=active?null:n
                      setActiveDisaster(gs.currentWave,next)
                      setKingDis(next)
                      notify(next?`👑 Disaster #${n}: ${name}`:'ยกเลิก Disaster')
                    }}
                    className={clsx(
                      'rounded-xl py-2 px-1 text-center transition-all active:scale-95 flex flex-col items-center gap-0.5',
                      active
                        ?'bg-yellow-500/20 border border-yellow-400/45 text-yellow-300'
                        :'glass-light text-slate-600 hover:text-slate-400 border border-transparent hover:border-white/8'
                    )}>
                    <span className="text-lg leading-none">{D_EMOJI[i]}</span>
                    <span className="text-2xs font-display">{name}</span>
                  </button>
                )
              })}
            </div>
            {kingDis && (
              <div className="flex items-center justify-between px-3 py-2 rounded-xl
                bg-yellow-500/8 border border-yellow-500/15 text-xs text-yellow-400">
                <span>{D_EMOJI[(kingDis-1)%9]} Active #{kingDis}</span>
                <button onClick={()=>{setActiveDisaster(gs.currentWave,null);setKingDis(null)}}
                  className="text-yellow-600 hover:text-yellow-400 transition-colors text-base leading-none">×</button>
              </div>
            )}
          </div>

          {/* Auction processor */}
          <div className="site-card-soft p-5">
            <p className="text-label mb-4">Auction</p>
            <button onClick={processWave} disabled={processing}
              className="btn w-full py-3 text-sm gap-2 mb-2 disabled:opacity-50"
              style={{
                background:'linear-gradient(135deg,#7c3aed,#a78bfa)',
                boxShadow:'0 0 20px rgba(124,58,237,0.3)',
              }}>
              <Zap size={15} fill="currentColor" />
              {processing?'กำลังประมวลผล…':`ประมวลผล Wave ${gs.currentWave}`}
            </button>
            <button onClick={resetMap}
              className="btn btn-ghost w-full py-2 text-xs gap-2 text-slate-500 hover:text-red-400">
              <RotateCcw size={12} /> Reset Map ทั้งหมด
            </button>
            <p className="text-2xs text-slate-700 text-center mt-2">ผู้ประมูลสูงสุด = ผู้ชนะพื้นที่</p>
          </div>

          {/* Quick stats */}
          <div className="site-card-soft p-5">
            <p className="text-label mb-3">Quick Stats</p>
            <div className="space-y-2">
              {[
                {label:`Submissions W${gs.currentWave}`, val:`${submittedBaans.length}/12`, color:'text-cyan-400'},
                {label:'พื้นที่ที่ถูกครอง', val:`${Object.values(ownership).filter(v=>v>0).length}/20`, color:'text-green-400'},
                {label:'รอส่งข้อมูล', val:String(12-submittedBaans.length), color:'text-orange-400'},
              ].map(s=>(
                <div key={s.label}
                  className="flex items-center justify-between site-card-soft px-3 py-2.5">
                  <span className="text-2xs text-slate-500">{s.label}</span>
                  <span className={clsx('font-mono font-bold text-sm', s.color)}>{s.val}</span>
                </div>
              ))}
            </div>
          </div>

          {/* Mini leaderboard */}
          <div className="site-card-soft p-5">
            <p className="text-label mb-3">Total Score</p>
            <Scoreboard entries={totalScores} compact />
          </div>
        </div>
      </div>
    </div>
  )
}

export default function AdminPage() {
  return (
    <AuthGuard pageKey="web5" expectedPassword="web5"
      title="Admin Panel" subtitle="กรอกรหัส Admin เพื่อเข้าสู่ระบบ"
      accentColor="#3b82f6">
      <AdminContent />
    </AuthGuard>
  )
}
